<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<!-- Changed root to VBox with alignment="CENTER" -->
<VBox alignment="CENTER" prefHeight="450.0" prefWidth="650.0" spacing="40.0" styleClass="content-area" stylesheets="@../application.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.controller.WelcomeController">
   <children>
      
      <!-- Headers Area -->
      <VBox alignment="CENTER" spacing="12.0">
         <children>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" styleClass="sub-header-text" text="Welcome" textAlignment="CENTER" />
            <Text strokeType="OUTSIDE" strokeWidth="0.0" styleClass="header-text" text="Seneca Auto Loan" textAlignment="CENTER" />
         </children>
      </VBox>
      
      <!-- Buttons Area -->
      <HBox alignment="CENTER" spacing="20.0">
         <children>
            <Button fx:id="goToSignUpBtn" mnemonicParsing="false" onAction="#handleWelcomeButtons" prefHeight="45.0" prefWidth="180.0" styleClass="primary-button" text="Sign Up" />
            <Button fx:id="goToLoginBtn" mnemonicParsing="false" onAction="#handleWelcomeButtons" prefHeight="45.0" prefWidth="180.0" styleClass="secondary-button" text="Login" />
         </children>
      </HBox>
      
   </children>
</VBox>
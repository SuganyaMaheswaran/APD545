<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="20.0" styleClass="content-area" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.controller.ViewCustomersController">
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <!-- Header matching the Loan Application page -->
    <Label text="Saved Customer Loans" styleClass="header-text" />
    
    <TableView fx:id="tvSavedLoans" prefHeight="400.0" prefWidth="700.0" VBox.vgrow="ALWAYS">

        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
        
        <columns>
           
            <TableColumn fx:id="colName" prefWidth="150.0" text="Name" styleClass="align-left" />
            <TableColumn fx:id="colPhoneNumber" prefWidth="100.0" text="Phone" styleClass="align-center" />
            <TableColumn fx:id="colLoanAmount" text="Borrowed" styleClass="align-right" />
            <TableColumn fx:id="colMonthlyPayment" text="Monthly Pmt" styleClass="align-right" />
            <TableColumn fx:id="colTotalRepayment" text="Total Paid" styleClass="align-right" />
            <TableColumn fx:id="colInterestRate" prefWidth="60.0" text="Rate %" styleClass="align-center" />
            <TableColumn fx:id="colVehicleType" prefWidth="100.0" text="Vehicle Type" styleClass="align-center" />
        </columns>
    </TableView>
    
    <HBox alignment="CENTER" spacing="15.0">

        <Button mnemonicParsing="false" onAction="#handleLoadSelected" text="Load Selected Customer into Form" styleClass="primary-button" prefHeight="35.0" />
    </HBox>

</VBox>